rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Helper for simulation bypass to allow local-only testing
    function isSimulationAccess(pathId) {
      return pathId.matches('.*sim-vendor-radha.*') || 
             pathId.matches('.*sim-admin-123.*') ||
             pathId.matches('.*radha-hospital-in.*');
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.email == 'digitalised17@gmail.com' && request.auth.token.email_verified == true) ||
        (request.auth.token.email == 'radha@hospital.in') ||
        (request.auth.token.email == 'admin@globalmaa.com') ||
        (request.auth.token.email == 'globalmedaccessalliance@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isDeveloper() {
      return isSignedIn() && (
        request.auth.token.email == 'digitalised17@gmail.com' ||
        request.auth.token.email == 'globalmedaccessalliance@gmail.com'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() || isSimulationAccess(userId);
      allow write: if (isSignedIn() && (request.auth.uid == userId || isDeveloper())) || isSimulationAccess(userId);
    }

    match /tenders {
      allow read: if true;
      match /{tenderId} {
        allow read: if true;
        allow write: if isAdmin() || isDeveloper();

        match /chats/{chatId}/messages/{messageId} {
          allow read, write: if isAdmin() || isDeveloper() || (isSignedIn() && request.auth.uid == chatId) || isSimulationAccess(chatId);
        }
      }
    }

    match /bids/{bidId} {
      allow read: if isSignedIn() || isSimulationAccess(bidId) || true; // Broaden read for the simulation leaderboard
      allow create: if (isSignedIn() && request.resource.data.vendorId == request.auth.uid) || isDeveloper() || isSimulationAccess(request.resource.data.vendorId);
      allow update: if isAdmin() || isDeveloper() || (isSignedIn() && resource.data.vendorId == request.auth.uid) || isSimulationAccess(resource.data.vendorId);
      allow delete: if isAdmin() || isDeveloper() || (isSignedIn() && resource.data.vendorId == request.auth.uid);
    }

    match /support_tickets/{ticketId} {
      allow read, write: if isAdmin() || isDeveloper() || isSimulationAccess(ticketId);
      allow read: if (isSignedIn() && resource.data.vendorId == request.auth.uid) || isSimulationAccess(ticketId);
      allow create: if (isSignedIn() && request.resource.data.vendorId == request.auth.uid) || isSimulationAccess(request.resource.data.vendorId);
      allow update: if (isSignedIn() && resource.data.vendorId == request.auth.uid) || isSimulationAccess(resource.data.vendorId);

      match /messages/{messageId} {
        allow read, write: if isAdmin() || isDeveloper() || isSimulationAccess(ticketId);
        allow read, create: if (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.vendorId == request.auth.uid) || isSimulationAccess(ticketId);
        allow update, delete: if isAdmin() || isDeveloper() || isSimulationAccess(ticketId);
      }
    }

    match /consultations/{id} {
      allow create: if true;
      allow read, write: if isAdmin() || isDeveloper();
    }

    match /leads/{leadId} {
      allow read, write: if isAdmin() || isDeveloper() || isSimulationAccess(leadId);
      allow read, create, update: if isSignedIn() || isSimulationAccess(leadId);
      allow delete: if isAdmin() || isDeveloper();

      match /messages/{messageId} {
         allow read, write: if isAdmin() || isDeveloper() || isSimulationAccess(leadId);
         allow read, create: if isSignedIn() || isSimulationAccess(leadId);
      }

      match /documents/{docId} {
         allow read, write: if isAdmin() || isDeveloper() || isSimulationAccess(leadId);
         allow read, create: if isSignedIn() || isSimulationAccess(leadId);
      }
    }

    match /support_threads/{userId} {
      allow read, write: if isAdmin() || isDeveloper() || (isSignedIn() && request.auth.uid == userId);

      match /messages/{messageId} {
        allow read, write: if isAdmin() || isDeveloper() || (isSignedIn() && request.auth.uid == userId);
      }
    }
  }
}
